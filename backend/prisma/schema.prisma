datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String               @id @default(uuid())
  email          String               @unique
  passwordHash   String?              // Nullable for Google Auth users
  username       String               @unique
  fullName       String
  avatarUrl      String?
  bio            String?
  status         String               @default("Active") // Active, Away, Do Not Disturb, Offline
  isOnboarded    Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  messages       Message[]
  conversations  Participant[]
  pinnedChats    PinnedConversation[]
  reactions      Reaction[]
}

model Conversation {
  id           String               @id @default(uuid())
  name         String?              // Nullable for DMs
  isGroup      Boolean              @default(false)
  avatarUrl    String?              // Group avatar
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  participants Participant[]
  messages     Message[]
  pinnedBy     PinnedConversation[]
}

model Participant {
  id             String       @id @default(uuid())
  userId         String
  conversationId String
  joinedAt       DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isSystem       Boolean       @default(false)
  replyToId      String?
  isEdited       Boolean       @default(false)
  isDeleted      Boolean       @default(false)
  fileUrl        String?       // File attachment URL
  fileName       String?       // File display name
  fileType       String?       // image, pdf, voice_note, etc.
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?      @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]     @relation("MessageReplies")
  reactions    Reaction[]
  reads        MessageRead[]
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model PinnedConversation {
  id             String   @id @default(uuid())
  userId         String
  conversationId String
  pinnedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}
